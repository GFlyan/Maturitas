{
  "expo": {
    "name": "Maturitas",
    "slug": "maturitas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": ""
    },
